OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:2b
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_MODEL=qwen/qwen3.5-9b
# 可选：为四个逻辑智能体指定 LM Studio 中的异构模型；留空则使用界面所选模型
UNDERSTANDING_MODEL=
SOLVER_MODEL=
DIAGNOSIS_MODEL=
TUTOR_MODEL=
DEFAULT_MODEL_PROVIDER=lmstudio
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL_PATH=models/paraphrase-multilingual-MiniLM-L12-v2
# 可选：接入 PDF-Extract-Kit / Docling 等布局与 OCR 服务的统一适配端点
PDF_EXTRACTOR_URL=
# macOS 扫描 PDF 默认自动回退 Vision OCR；off 可关闭，Linux/Windows 建议配置上方外部解析器
PDF_LOCAL_OCR=auto
REDIS_URL=redis://127.0.0.1:6379/0
SESSION_HISTORY_MESSAGES=100
# 送入模型的近期对话轮数；完整历史仍由 SESSION_HISTORY_MESSAGES 持久化
MEMORY_TURNS=24
MAX_OLLAMA_CONCURRENCY=2
REMOTE_MAX_TOKENS=8192
REMOTE_MAX_CONTINUATIONS=2
MAX_ATTACHMENT_MB=20
MAX_CHAT_ATTACHMENTS=5
# 仅限制首个可见 token：超过此时间仍无正文输出才中止；开始输出后不设总时限
CHAT_FIRST_TOKEN_TIMEOUT_SECONDS=600
INITIAL_CHAPTER_LIMIT=1
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
OMP_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
VECLIB_MAXIMUM_THREADS=1
TOKENIZERS_PARALLELISM=false
