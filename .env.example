OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:2b
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_MODEL=qwen/qwen3.5-9b
# 可选：为四个逻辑智能体指定 LM Studio 中的异构模型；留空则使用界面所选模型
UNDERSTANDING_MODEL=
SOLVER_MODEL=
DIAGNOSIS_MODEL=
TUTOR_MODEL=
DEFAULT_MODEL_PROVIDER=lmstudio
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VISION_MODEL=qwen3-vl-flash
QWEN_CIRCUIT_VISION_MODEL=qwen3-vl-flash
QWEN_CLEANING_MODEL=qwen3.7-plus
QWEN_VISION_MAX_TOKENS=8192
QWEN_MULTIMODAL_EMBEDDING_MODEL=qwen3-vl-embedding
QWEN_MULTIMODAL_EMBEDDING_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/multimodal-embedding/multimodal-embedding
QWEN_MULTIMODAL_EMBEDDING_DIMENSION=1024
QWEN_MULTIMODAL_TIMEOUT_SECONDS=180
EMBEDDING_MODEL_PATH=models/paraphrase-multilingual-MiniLM-L12-v2
# 可选：接入 PDF-Extract-Kit / Docling 等布局与 OCR 服务的统一适配端点
PDF_EXTRACTOR_URL=
# macOS 扫描 PDF 默认自动回退 Vision OCR；off 可关闭，Linux/Windows 建议配置上方外部解析器
PDF_LOCAL_OCR=auto
REDIS_URL=redis://127.0.0.1:6379/0
SESSION_HISTORY_MESSAGES=100
# 送入模型的近期对话轮数；完整历史仍由 SESSION_HISTORY_MESSAGES 持久化
MEMORY_TURNS=24
MAX_OLLAMA_CONCURRENCY=2
REMOTE_MAX_TOKENS=8192
REMOTE_MAX_CONTINUATIONS=2
MAX_ATTACHMENT_MB=20
MAX_CHAT_ATTACHMENTS=5
# 仅限制首个可见 token：超过此时间仍无正文输出才中止；开始输出后不设总时限
CHAT_FIRST_TOKEN_TIMEOUT_SECONDS=600
INITIAL_CHAPTER_LIMIT=1
QDRANT_URL=
QDRANT_API_KEY=
NEO4J_URI=
NEO4J_HTTP_URL=http://127.0.0.1:7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
# PDF-Extract-Kit/MinerU worker 导出的结构化 JSON 目录（每本书 <PDF文件名不含扩展名>.json）
PDF_EXTRACT_KIT_OUTPUT_DIR=
PDF_EXTRACT_KIT_DIR=third_party/PDF-Extract-Kit
# 0=处理全部页；开发联调建议 3~8 页
PDF_EXTRACT_KIT_PAGE_LIMIT=0
# 本地 CrossEncoder 模型目录；留空时降级为融合重排
RERANK_MODEL_PATH=
MULTIMODAL_IMAGE_LIMIT=0
MULTIMODAL_MIN_IMAGE_AREA=12000
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
OMP_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
VECLIB_MAXIMUM_THREADS=1
TOKENIZERS_PARALLELISM=false
